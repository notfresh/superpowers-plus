+# Scenario 2: Existing Hook (merge)
+# ============================================================================
+
+test_scenario_2_existing_hook_merge() {
+  echo "  1. Creating existing hook..."
+  cat > "$HOME/.claude/hooks/sessionEnd" <<'EOF'
